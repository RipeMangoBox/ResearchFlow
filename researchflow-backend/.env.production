# ============================================================
# ResearchFlow Production Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Database ────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random password!
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD

# ── Domain ──────────────────────────────────────────────────
# Your domain name. Caddy will auto-provision HTTPS via Let's Encrypt.
# Use "localhost" for local-only access (no HTTPS).
DOMAIN=rf.example.com

# ── LLM API Keys ───────────────────────────────────────────
# At least one is required for real analysis. Without both, system runs in mock mode.
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── Object Storage (optional) ──────────────────────────────
# "local" = store PDFs on server disk (default, free)
# "cos"   = store on Tencent Cloud COS (recommended for production)
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=researchflow-1234567890
OBJECT_STORAGE_SECRET_ID=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=ap-shanghai

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
