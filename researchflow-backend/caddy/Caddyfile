{$DOMAIN:localhost} {
    # API
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /docs {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }

    # MCP SSE server (remote connection for Claude Code)
    handle /sse {
        reverse_proxy mcp:8001
    }
    handle /messages/* {
        reverse_proxy mcp:8001
    }

    # Frontend (everything else)
    handle {
        reverse_proxy frontend:3000
    }
}
