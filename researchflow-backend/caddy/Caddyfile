{$DOMAIN:localhost} {
    # API
    handle /api/* {
        reverse_proxy api:8000
    }

    # MCP endpoint (for Claude Code / Codex)
    handle /mcp/* {
        reverse_proxy api:8000
    }

    # Health
    handle /health {
        reverse_proxy api:8000
    }

    # Frontend (everything else)
    handle {
        reverse_proxy frontend:3000
    }
}
