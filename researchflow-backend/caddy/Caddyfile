{$DOMAIN:localhost} {
    # API + MCP
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /mcp/* {
        reverse_proxy api:8000
    }
    handle /docs {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }

    # Frontend (everything else)
    handle {
        reverse_proxy frontend:3000
    }
}
